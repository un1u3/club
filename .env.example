# ── CLUB Environment Variables ─────────────────────────────
# Copy this file to .env and edit values as needed.
# All values below are optional — CLUB works with defaults.

# ── Ollama Settings ───────────────────────────────────────
# Base URL for the ollama server (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (default: llama3)
OLLAMA_MODEL=llama3

# ── Tesseract OCR ────────────────────────────────────────
# Path to tesseract binary (only needed if not on PATH)
# TESSERACT_CMD=/usr/bin/tesseract

# ── Chainlit Settings ────────────────────────────────────
# Port for the Chainlit web UI (default: 8000)
CHAINLIT_PORT=8000

# Host binding (default: 0.0.0.0 for LAN access)
CHAINLIT_HOST=0.0.0.0
